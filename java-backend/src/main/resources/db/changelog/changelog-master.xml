<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">


    <changeSet author="Sourav Das" id="1" >
        <createTable tableName="users"  >
            <column name="id" type="INTEGER" autoIncrement="true">
                <constraints primaryKey="true"></constraints>
            </column>
            <column name="name" type="VARCHAR(250)"></column>
            <column name="phone_no" type="VARCHAR(15)"></column>
            <column name="email" type="VARCHAR(256)"></column>
            <column name="profile_pic" type="VARCHAR(256)"></column>
            <column name="uuid" type="VARCHAR(256)"></column>
        </createTable>

    </changeSet>
    <changeSet id="2" author="SD25">
        <validCheckSum>ANY</validCheckSum>
        <createTable tableName="groups" >
            <column name="id" type="INTEGER" autoIncrement="true">
                <constraints primaryKey="true"></constraints>
            </column>
            <column name="name" type="VARCHAR(250)"></column>
        </createTable>
        <createTable tableName="user_groups" >
            <column name="user_id" type="INTEGER"></column>
            <column name="group_id" type="INTEGER"></column>
            <column name="id" type="INTEGER" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseColumnNames="user_id"
                                 baseTableName="user_groups"
                                 constraintName="fk_user_groups_user_id"
                                 referencedColumnNames="id"
                                 referencedTableName="users"/>

        <addForeignKeyConstraint baseColumnNames="group_id"
                                 baseTableName="user_groups"
                                 constraintName="fk_user_groups_group_id"
                                 referencedColumnNames="id"
                                 referencedTableName="groups"/>
        <createTable tableName="chat_messages" >
            <column name="id" type="INTEGER" autoIncrement="true" >
                <constraints primaryKey="true"/>
            </column>
            <column name="group_id" type="INTEGER"/>
            <column name="user_id" type="INTEGER"/>
            <column name="message" type="VARCHAR(512)"/>
            <column name="created_at" type="TIMESTAMP" defaultValue="NOW()" >
                <constraints nullable="false"/>
            </column>
            <column name="read" type="INTEGER"/>
        </createTable>
    </changeSet>
    <changeSet id="3" author="SD">
        <addUniqueConstraint tableName="users" columnNames="phone_no"/>
    </changeSet>
    <changeSet id="4" author="SD">
        <renameColumn tableName="chat_messages" oldColumnName="read" newColumnName="is_read" columnDataType="INTEGER"/>
    </changeSet>
</databaseChangeLog>

