# Tracko Environment Variables Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tracko_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# Firebase Configuration (for Flutter app)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket

# API Configuration
JAVA_BACKEND_URL=http://localhost:8080
PYTHON_BACKEND_URL=http://localhost:8000

# SAP HANA Configuration (if using)
HANA_HOST=hanatrial.ondemand.com
HANA_USER=your_hana_user
HANA_PASSWORD=your_hana_password
HANA_INSTANCE=hanamdc

# Google Ads (Flutter)
GOOGLE_ADS_APP_ID=your_google_ads_app_id
GOOGLE_ADS_BANNER_ID=your_banner_ad_id

# Environment
NODE_ENV=development
DJANGO_DEBUG=True
SPRING_PROFILES_ACTIVE=local
